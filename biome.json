{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!packages/dashboard/src/route-tree.gen.ts",
      "!packages/i18n/project.inlang/.meta.json",
      "!packages/i18n/src/paraglide"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "unsafe",
          "options": {
            "attributes": ["className", "class"],
            "functions": ["cn", "cva"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/dashboard/src/components/ui/**"],
      "linter": {
        "enabled": false
      }
    }
  ],
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}

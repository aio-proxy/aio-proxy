{
  "name": "@aio-proxy/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./paraglide/*": {
      "types": "./src/paraglide/*.d.ts",
      "default": "./src/paraglide/*.js"
    }
  },
  "scripts": {
    "build": "paraglide-js compile --emit-ts-declarations",
    "dev": "bun run build --watch",
    "test": "bun run test:unit",
    "test:unit": "cd ../.. && bun test packages/i18n/_test/*.test.ts"
  },
  "dependencies": {
    "@inlang/paraglide-js": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "typescript": "catalog:"
  }
}

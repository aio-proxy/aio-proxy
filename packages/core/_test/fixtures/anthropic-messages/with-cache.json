{
  "model": "claude-sonnet-4-5",
  "max_tokens": 256,
  "stream": true,
  "temperature": 0.2,
  "messages": [
    {
      "role": "user",
      "content": [
        {
          "type": "text",
          "text": "Use this context.",
          "cache_control": {
            "type": "ephemeral",
            "ttl": "1h"
          }
        }
      ]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "tool_use",
          "id": "toolu_cache",
          "name": "remember",
          "input": {
            "topic": "context"
          },
          "cache_control": {
            "type": "ephemeral"
          }
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "toolu_cache",
          "content": "Stored",
          "cache_control": {
            "type": "ephemeral",
            "ttl": "5m"
          }
        }
      ]
    }
  ]
}

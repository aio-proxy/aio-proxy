{
  "name": "@aio-proxy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./db/schema/auth": {
      "types": "./dist/db/schema/auth.d.ts",
      "import": "./dist/db/schema/auth.js",
      "default": "./dist/db/schema/auth.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch",
    "build:migrations": "bun x drizzle-kit generate --config=drizzle.config.ts",
    "test": "bun run test:unit",
    "test:unit": "bun test _test"
  },
  "dependencies": {
    "@aio-proxy/types": "workspace:*",
    "ai": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/xai": "catalog:",
    "@ai-sdk/provider": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "@rslib/core": "catalog:",
    "@types/bun": "catalog:",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}

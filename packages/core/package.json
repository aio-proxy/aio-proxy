{
  "name": "@aio-proxy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/schema/*": {
      "types": "./dist/db/schema/*.d.ts",
      "default": "./dist/db/schema/*.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch --no-clean",
    "build:migrations": "bun scripts/build-migrations.ts",
    "test": "bun run test:unit",
    "test:unit": "bun test",
    "test:artifact": "bun test ./_test/build-entry.smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "@ai-sdk/provider": "catalog:",
    "@ai-sdk/xai": "catalog:",
    "@aio-proxy/i18n": "workspace:*",
    "@aio-proxy/logger": "workspace:*",
    "@aio-proxy/plugin-github-copilot": "workspace:*",
    "@aio-proxy/plugin-google-antigravity": "workspace:*",
    "@aio-proxy/plugin-kimi-code": "workspace:*",
    "@aio-proxy/plugin-openai-chatgpt": "workspace:*",
    "@aio-proxy/plugin-sdk": "workspace:*",
    "@aio-proxy/plugin-xai-grok": "workspace:*",
    "@aio-proxy/types": "workspace:*",
    "@anthropic-ai/sdk": "catalog:",
    "@google/genai": "catalog:",
    "@handlebars/parser": "2.2.2",
    "@opencode-ai/models": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "ai": "catalog:",
    "drizzle-orm": "catalog:",
    "es-toolkit": "catalog:",
    "openai": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "@rslib/core": "catalog:",
    "@types/bun": "catalog:",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}

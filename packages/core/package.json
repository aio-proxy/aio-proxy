{
  "name": "@aio-proxy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema/auth": "./src/db/schema/auth.ts"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch --no-clean",
    "build:migrations": "bun x drizzle-kit generate --config=drizzle.config.ts && bun scripts/build-migrations-manifest.ts",
    "test": "bun run test:unit",
    "test:unit": "bun test _test"
  },
  "dependencies": {
    "@aio-proxy/types": "workspace:*",
    "ai": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/xai": "catalog:",
    "@ai-sdk/provider": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "@rslib/core": "catalog:",
    "@types/bun": "catalog:",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}

{
  "name": "@aio-proxy/provider-schemas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun --bun rslib",
    "dev": "bun --bun rslib --watch --no-clean",
    "test": "bun run test:unit",
    "test:unit": "cd ../.. && bun test packages/provider-schemas/_test/*.test.ts",
    "test:integration": "cd ../.. && bun test ./packages/provider-schemas/_test/provider-schemas.integration.ts && bun test ./packages/provider-schemas/_test/clean-dist-smoke.ts && bun test ./packages/provider-schemas/_test/runtime-leakage-smoke.ts"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "@babel/parser": "7.28.5",
    "@rslib/core": "catalog:",
    "@types/bun": "catalog:",
    "typebox": "1.3.6",
    "typescript": "catalog:"
  }
}

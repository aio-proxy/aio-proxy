{
  "extends": "@aio-proxy/infra/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": [
      "@rsbuild/core/types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "references": [
    {
      "path": "../i18n"
    },
    {
      "path": "../server"
    }
  ]
}
{
  "name": "@aio-proxy/cli",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "biome check . && tsc -b --pretty false",
    "test": "bun run test:unit",
    "test:unit": "bun test _test",
    "e2e": "bun -e \"process.exit(0)\"",
    "start": "bun src/main.ts serve",
    "dev": "bun -e \"process.exit(0)\""
  },
  "dependencies": {
    "@aio-proxy/core": "workspace:*",
    "@aio-proxy/i18n": "workspace:*",
    "@aio-proxy/server": "workspace:*",
    "@aio-proxy/types": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "commander": "15"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "catalog:"
  }
}

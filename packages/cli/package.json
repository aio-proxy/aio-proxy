    "@aio-proxy/server": "workspace:*",
    "@aio-proxy/types": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "commander": "15"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}

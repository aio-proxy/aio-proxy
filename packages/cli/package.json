{
  "name": "@aio-proxy/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build:binary": "bun scripts/build-binary.ts",
    "test": "bun run test:unit",
    "test:unit": "bun test --preload=./_test/setup.ts",
    "serve:dev": "AIO_PROXY_HOME=../../.aio-proxy-dev bun --watch src/main.dev.ts serve",
    "start": "bun src/main.ts serve"
  },
  "dependencies": {
    "@aio-proxy/core": "workspace:*",
    "@aio-proxy/dashboard": "workspace:*",
    "@aio-proxy/i18n": "workspace:*",
    "@aio-proxy/logger": "workspace:*",
    "@aio-proxy/plugin-sdk": "workspace:*",
    "@aio-proxy/server": "workspace:*",
    "@aio-proxy/types": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "commander": "15",
    "es-toolkit": "catalog:"
  },
  "devDependencies": {
    "@aio-proxy/infra": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
